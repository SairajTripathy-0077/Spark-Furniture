datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

model Product {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  price         Float
  originalPrice Float?
  rating        Float    @default(4.5)
  reviewsCount  Int      @default(0)
  category      String
  description   String
  colors        String   // JSON array of colors: [{"name":"...", "hex":"..."}]
  imageType     String?  // 'chair', 'table', 'sofa', 'lamp', 'storage' (used for default sketches)
  imageUrl      String?  // Uploaded image from Cloudinary
  imageUrls     String[] @default([]) // Array of all uploaded images
  badge         String?  // 'Sale', 'New', 'Limited', etc.
  inStock       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  customerName    String
  customerPhone   String
  customerEmail   String?
  customerAddress String   @default("")
  totalAmount     Float
  status          String   @default("pending") // "pending", "completed", "cancelled"
  items           String   // JSON array of cart items: [{"id":"...", "name":"...", "price":..., "quantity":..., "selectedColor":"...", "imageType":"..."}]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Category {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  createdAt DateTime @default(now())
}
